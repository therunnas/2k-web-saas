# =====================================================================
# 2K Web SaaS — .gitignore (raiz do monorepo)
# =====================================================================

# ----- Dependências -----
node_modules/
**/node_modules/

# ----- Next.js -----
.next/
**/.next/
out/
**/out/
build/
**/build/

# ----- Variáveis de ambiente (BLOQUEADAS) -----
# Bloqueamos qualquer .env* recursivo e liberamos o template .env.example.
.env
.env.*
**/.env
**/.env.*
!.env.example
!**/.env.example

# ----- Prisma / cliente gerado / banco local -----
**/src/generated/prisma
*.db
*.db-journal
**/*.db
**/prisma/dev.db

# ----- Logs -----
*.log
**/*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ----- Backups / caches -----
.cleanup-backup/
**/.cleanup-backup/
.turbo/
**/.turbo/

# ----- Vercel -----
.vercel/
**/.vercel/

# ----- TypeScript -----
*.tsbuildinfo
**/*.tsbuildinfo
next-env.d.ts
**/next-env.d.ts

# ----- OS / editor -----
.DS_Store
Thumbs.db
.vscode/
.idea/
*.pem
*.tmp
*.swp
*~

# ----- Misc -----
dist/
**/dist/
coverage/
**/coverage/
