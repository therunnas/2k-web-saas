generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  username     String?  @unique
  passwordHash String
  avatarDataUrl String?  @db.Text
  role         UserRole @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspaces WorkspaceMember[]
}

model Workspace {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  setupCompleted Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  members           WorkspaceMember[]
  settings          WorkspaceSettings?
  discordConnection DiscordConnection?
  imports           Import[]
  financialEntries  FinancialEntry[]
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String
  role        UserRole @default(ADMIN)
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

model WorkspaceSettings {
  id                       String   @id @default(cuid())
  workspaceId              String   @unique
  companyConfigured        Boolean  @default(false)
  discordConfigured        Boolean  @default(false)
  defaultChannelConfigured Boolean  @default(false)
  spreadsheetConfigured    Boolean  @default(false)
  setupCompleted           Boolean  @default(false)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model DiscordConnection {
  id                 String    @id @default(cuid())
  workspaceId        String    @unique
  guildId            String?
  guildName          String?
  defaultChannelId   String?
  defaultChannelName String?
  connectedAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Import {
  id           String   @id @default(cuid())
  workspaceId  String
  fileName     String
  originalName String
  importedAt   DateTime @default(now())
  entriesCount Int      @default(0)
  outputsCount Int      @default(0)
  groupsCount  Int      @default(0)
  brandsCount  Int      @default(0)
  createdAt    DateTime @default(now())

  workspace        Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  financialEntries FinancialEntry[]
}

enum FinancialEntryType {
  REVENUE
  EXPENSE
  RECEIVABLE
  PAYABLE
  UNKNOWN
  LEAD
  CANCELED
}

model FinancialEntry {
  id          String             @id @default(cuid())
  workspaceId String
  importId    String?
  type        FinancialEntryType @default(UNKNOWN)

  date        DateTime?
  competence  String?
  client      String?
  groupName   String?
  project     String?
  description String?
  category    String?
  status      String?

  grossAmount   Decimal  @default(0) @db.Decimal(14, 2)
  costAmount    Decimal  @default(0) @db.Decimal(14, 2)
  profitAmount  Decimal  @default(0) @db.Decimal(14, 2)
  marginPercent Decimal? @db.Decimal(8, 2)

  sourceSheet String?
  sourceRow   Int?

  sourceType       String    @default("SPREADSHEET")
  isManual         Boolean   @default(false)
  editable         Boolean   @default(false)
  deletedAt        DateTime?
  manualKind       String?
  documentNumber   String?
  commercialStatus String?
  financialStatus  String?
  issuedAt         DateTime?
  dueAt            DateTime?
  paidAt           DateTime?
  supplierName     String?
  subCategory      String?
  nature           String?
  recurrence       String?
  notes            String?
  linkedClient     String?
  costCenter       String?
  paymentMethod    String?
  accountName      String?
  proofUrl         String?
  expectedAmount   Decimal?  @db.Decimal(14, 2)
  paidAmount       Decimal?  @db.Decimal(14, 2)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  import    Import?   @relation(fields: [importId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([importId])
  @@index([type])
  @@index([date])
  @@index([client])
  @@index([groupName])
}

model ManualCatalogItem {
  id          String   @id @default(cuid())
  workspaceId String
  type        String
  name        String
  parentName  String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([workspaceId, type, name])
  @@index([workspaceId, type])
}
