# =====================================================================
# 2K Web SaaS — .gitignore (apps/web)
# =====================================================================
# Mantenha sincronizado com o `.gitignore` da raiz do repositório.
# =====================================================================

# ----- Dependências -----
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ----- Testes / cobertura -----
/coverage

# ----- Next.js -----
/.next/
/out/
/build

# ----- Variáveis de ambiente (BLOQUEADAS) -----
# Bloqueamos qualquer .env* e depois liberamos o template público.
.env
.env.*
!.env.example

# ----- Prisma / banco local -----
# O cliente gerado nunca vai ao git — sempre regenerado pelo build.
/src/generated/prisma
# Banco SQLite local (caso alguém aponte DATABASE_URL para sqlite localmente).
*.db
*.db-journal
prisma/dev.db
prisma/*.db

# ----- Logs / debug -----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ----- TypeScript -----
*.tsbuildinfo
next-env.d.ts

# ----- Caches -----
.cleanup-backup/
.turbo/

# ----- Vercel -----
.vercel

# ----- Misc / OS / editor -----
.DS_Store
Thumbs.db
.vscode/
.idea/
*.pem
*.tmp
*.swp
*~
