# =====================================================================
# 2K Web SaaS — Template de variáveis de ambiente
# =====================================================================
# Copie este arquivo para `.env` e preencha com seus valores reais.
#
#   cp .env.example .env
#
# Nunca commite o `.env` no git — está no .gitignore por padrão.
# Esse arquivo (.env.example) NÃO deve conter segredos reais.
# =====================================================================


# ---------------------------------------------------------------------
# Banco de dados (obrigatório)
# ---------------------------------------------------------------------
# Connection string PostgreSQL. Em produção usamos Neon; em local pode
# ser qualquer Postgres acessível.
#
# Formato:
#   postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
#
# Para Neon, copie a "Pooled connection" do dashboard e ADICIONE o
# parâmetro `?sslmode=require` se ainda não estiver presente.
# ---------------------------------------------------------------------
DATABASE_URL="postgresql://usuario:senha@localhost:5432/2k_web_saas?schema=public"


# ---------------------------------------------------------------------
# Autenticação (obrigatório)
# ---------------------------------------------------------------------
# Segredo usado para assinar os JWTs da sessão (HS256 via `jose`).
# Mínimo recomendado: 32 caracteres. Gere com qualquer um destes:
#
#   openssl rand -base64 48
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
#
# IMPORTANTE: rotacionar este valor invalida TODAS as sessões ativas.
# ---------------------------------------------------------------------
AUTH_SECRET="troque-este-valor-por-um-segredo-aleatorio-de-pelo-menos-32-caracteres"


# ---------------------------------------------------------------------
# Ambiente
# ---------------------------------------------------------------------
# `development` (padrão local), `production` (Vercel/host) ou `test`.
# Controla o flag `Secure` do cookie de sessão, bloqueio de rotas /api/dev/*,
# logs de erro mais verbosos em dev, etc.
# ---------------------------------------------------------------------
NODE_ENV="development"


# ---------------------------------------------------------------------
# Seed do admin único (apenas em desenvolvimento)
# ---------------------------------------------------------------------
# Estas variáveis são lidas APENAS pela rota POST /api/dev/seed-admin,
# que está bloqueada em produção. Use elas para criar/atualizar o admin
# no banco local. NÃO precisam estar no ambiente de produção.
#
# ADMIN_PASSWORD precisa ter no mínimo 8 caracteres.
# ---------------------------------------------------------------------
ADMIN_EMAIL="admin@2kstudios.com"
ADMIN_PASSWORD="troque-esta-senha-local-e-use-uma-forte"
ADMIN_NAME="Admin 2K Studios"
